// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  // --- CAMPOS BÁSICOS ---
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  nome      String
  sobrenome String?
  email     String    @unique
  senha     String
  usuario   String?   @unique
  comments  Comment[] // Um usuário pode fazer vários comentários

  // --- CAMPOS PARA REDEFINIÇÃO DE SENHA ---
  resetPasswordToken String? // Guarda o token para redefinição de senha
  resetPasswordExpires DateTime? // Guarda a hora em que o token perde a validade

  // --- CAMPOS PARA VERIFICAÇÃO DE E-MAIL ---
  isEmailVerified         Boolean   @default(false) // Diz se o utilizador já validou o e-mail
  verificationCode        String? // Guarda o código de 6 dígitos (ex: "123456")
  verificationCodeExpires DateTime? // Guarda a hora em que o código perde a validade

  // --- CAMPOS PARA O PERFIL---
  imagem String? // URL ou Base64 da foto de perfil
  bio    String? // Pequeno texto sobre o dev
  funcao String? // Ex: "Front-end Developer", "Fullstack"

  // A relação inversa: um usuário pode ter múltiplos posts
  posts Post[]

  // --- SISTEMA DE SEGUIDORES  ---

  // 1. Quem este usuário ESTÁ SEGUINDO (Ele guarda a lista de IDs dos amigos)
  followingIds String[] @db.ObjectId
  following    User[]   @relation("UserFollows", fields: [followingIds], references: [id]) // Relaciona os IDs dos amigos com os usuários correspondentes

  // 2. Quem ESTÁ SEGUINDO este usuário (A relação inversa)
  followerIds String[] @db.ObjectId
  followers   User[]   @relation("UserFollows", fields: [followerIds], references: [id]) // Relaciona os IDs dos seguidores com os usuários correspondentes
}

// O novo model, baseado na sua ideia do Figma
model Post {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String // Equivalente ao "nome" da publicação
  content       String // Equivalente à "descricao"
  codeContent   String? // O código 
  image         String? // Equivalente à "imagem" (será a URL da imagem)
  imageFileName String? // Equivalente ao "nomeArquivo"
  tags          String[] // Lista de strings para as tags
  projectUrl    String? // Link do projeto no ar (Vercel, Netlify, etc)
  repoUrl       String? // Link do GitHub/GitLab
  createdAt     DateTime @default(now())

  comments Comment[] // Um post pode ter múltiplos comentários

  // --- A Relação com o User ---
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade) // Relaciona o post ao autor
  authorId String @db.ObjectId
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  text      String // O texto do comentário
  createdAt DateTime @default(now())

  // --- Quem comentou? ---
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String @db.ObjectId

  // --- Onde comentou? ---
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
}
